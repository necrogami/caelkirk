<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{block title}Shilla{/block}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
    {block head}{/block}
</head>
<body class="min-h-screen bg-twilight-bg text-text-primary font-['Inter',system-ui,sans-serif]">
    <header class="border-b border-twilight-border">
        <nav class="max-w-[640px] mx-auto flex items-center justify-between px-6 h-14">
            <div class="flex items-center gap-3">
                <span class="text-accent font-bold text-sm tracking-widest">SHILLA</span>
                {if isset($user)}
                <span class="text-twilight-border">|</span>
                <span class="text-text-secondary text-sm">{$user->username}</span>
                {/if}
            </div>
            <form method="POST" action="/logout">
                <button type="submit" class="text-text-muted hover:text-text-primary text-sm transition-colors duration-150">Log Out</button>
            </form>
        </nav>
    </header>

    <main class="max-w-[640px] mx-auto px-6 py-10">
        {block content}{/block}
    </main>
</body>
</html>
